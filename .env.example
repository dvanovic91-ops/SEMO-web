# OAuth — 구글/얀덱스 연동 (실제 연동 시 .env에 복사 후 값 채우기)

# Google: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# 백엔드 callback URL (구글 인증 후 코드를 받는 서버 주소)
VITE_GOOGLE_REDIRECT_URI=https://your-api-domain.com/auth/google/callback

# Yandex: https://oauth.yandex.ru/
VITE_YANDEX_CLIENT_ID=your-yandex-app-id
VITE_YANDEX_REDIRECT_URI=https://your-api-domain.com/auth/yandex/callback

# 지원(Support) 페이지 — 문의 메일 수신 주소 (선택)
# VITE_SUPPORT_EMAIL=support@your-domain.com

# Supabase — 프로젝트 URL과 anon(publishable) key (대시보드 → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Telegram user-бот (привязка аккаунта; дефолт в коде — @My_SEMO_Beautybot)
# VITE_TELEGRAM_BOT_URL=https://t.me/My_SEMO_Beautybot
