# OAuth — 구글/얀덱스 연동 (실제 연동 시 .env에 복사 후 값 채우기)

# Google: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# 백엔드 callback URL (구글 인증 후 코드를 받는 서버 주소)
VITE_GOOGLE_REDIRECT_URI=https://your-api-domain.com/auth/google/callback

# Yandex: https://oauth.yandex.ru/ — Callback URL 과 문자 단위로 동일해야 함 (www 유무 포함)
VITE_YANDEX_CLIENT_ID=your-yandex-app-id
# 프로덕션 필수 권장: https://semo-box.com/auth/yandex/callback (로그인 시작 도메인과 무관하게 고정)
VITE_YANDEX_REDIRECT_URI=https://your-domain.com/auth/yandex/callback

# 지원(Support) 페이지 — 문의 메일 수신 주소 (선택)
# VITE_SUPPORT_EMAIL=support@your-domain.com

# Supabase — 프로젝트 URL과 anon(publishable) key (대시보드 → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 회원가입 주소 자동완성:
# DaData API 키는 클라이언트에 노출하지 않음 — Supabase Edge Function (dadata-suggest) 서버 secret으로 설정
#   Supabase Dashboard → Edge Functions → dadata-suggest → Secrets → DADATA_API_KEY
# Google Maps Places (RF 외 국가): HTTP 리퍼러 제한 필수 (Google Cloud Console → API 키 → 앱 제한 → semo-box.com/*)
# VITE_GOOGLE_MAPS_API_KEY=

# 피부 분석·성분 수집 Flask API (무제 폴더 main.py 기본 포트 5001)
# - 비우면: `npm run dev`에서는 코드 기본값 `/skin-api`(Vite → 127.0.0.1:5001 프록시). 로컬에서 Flask만 켜 두면 됨.
# - 명시하려면(프리뷰·다른 포트 등): 아래처럼 직접 URL 지정.
# VITE_SKIN_API_URL=http://127.0.0.1:5001

# Telegram user-бот (привязка аккаунта; дефолт в коде — @My_SEMO_Beautybot)
# VITE_TELEGRAM_BOT_URL=https://t.me/My_SEMO_Beautybot
